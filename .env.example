# ---------------------------------------------------------------------------
# Paperly — environment variables. Copy this file to `.env` and fill in values.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Used by the Prisma CLI (migrations / db push / seed).
# Local development uses a SQLite file:
DATABASE_URL="file:./prisma/dev.db"

# Runtime database connection, read by the libSQL driver adapter.
#   Local dev  -> point at the same local SQLite file as DATABASE_URL.
#   Production -> your Turso database URL, e.g. libsql://your-db.turso.io
TURSO_DATABASE_URL="file:./prisma/dev.db"

#   Local dev  -> leave empty.
#   Production -> your Turso auth token (from `turso db tokens create <db>`).
TURSO_AUTH_TOKEN=""

# Secret used to sign session JWTs. MUST be set. Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="change-me-to-a-long-random-string"
